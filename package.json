{
  "name": "masjidnurulhuda",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "test": "node --test tests/**/*.test.mjs",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name masjidnurulhuda",
    "db:create": "wrangler d1 migrations create masjidnurulhuda-db",
    "db:apply:local": "wrangler d1 migrations apply masjidnurulhuda-db --local",
    "db:apply:remote": "wrangler d1 migrations apply masjidnurulhuda-db --remote",
    "db:drop:local": "wrangler d1 execute masjidnurulhuda-db --local --command=\"DROP TABLE IF EXISTS d1_migrations; DROP TABLE IF EXISTS kas_masjid; DROP TABLE IF EXISTS users; DROP TABLE IF EXISTS kategori_kas; DROP TABLE IF EXISTS periode; DROP TABLE IF EXISTS seksi_pengurus;\"",
    "db:reset:local": "npm run db:drop:local && npm run db:apply:local"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@headlessui/vue": "^1.7.23",
    "@hono/vite-dev-server": "^0.25.1",
    "@vueuse/core": "^14.2.1",
    "browser-image-compression": "^2.0.2",
    "hono": "^4.12.14",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.83.0"
  }
}
